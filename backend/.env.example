# ── Backend environment (copy to .env and fill in) ──────────────────────

# HTTP
PORT=5001
# HOST=0.0.0.0                       # Railway задаёт сам; локально можно не трогать
# NODE_ENV=production                # ставится автоматически на Railway

# Разрешённые origin'ы фронтенда (через запятую).
# localhost и *.railway.app разрешены автоматически — здесь только доп. адреса.
CLIENT_URL=http://localhost:3000,http://localhost:3005

# MongoDB
MONGODB_URI=mongodb://user:password@host:port

# Tigris (S3-совместимое хранилище)
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_BUCKET=vkr-audit-files

# Необязательно: путь к собранному фронтенду для монолит-деплоя
# CLIENT_BUILD_PATH=../client/build
